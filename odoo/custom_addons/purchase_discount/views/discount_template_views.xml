<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_discount_list" model="ir.ui.view">
        <field name="name">purchase.discount.list</field>
        <field name="model">purchase.discount</field>
        <field name="arch" type="xml">
            <list string="Purchase Discounts">
                <field name="name"/>
                <field name="discount_type"/>
                <field name="discount_value"/>
            </list>
        </field>
    </record>

    <record id="view_purchase_discount_form" model="ir.ui.view">
        <field name="name">purchase.discount.form</field>
        <field name="model">purchase.discount</field>
        <field name="arch" type="xml">
            <form string="Purchase Discount">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="discount_type" widget="radio"/>
                        <field name="discount_value"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_purchase_discount" model="ir.actions.act_window">
        <field name="name">Discounts</field>
        <field name="res_model">purchase.discount</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_purchase_discount"
        name="Discounts"
        action="action_purchase_discount"
        parent="purchase.menu_purchase_config"
        sequence="30"
    />
</odoo>
