<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Construction BOQ Form View -->
        <record id="view_construction_boq_form" model="ir.ui.view">
            <field name="name">construction.boq.form</field>
            <field name="model">construction.boq</field>
            <field name="arch" type="xml">
                <form string="Bill of Quantities">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="project_id"/>
                            </group>
                            <group>
                                <field name="total_planned" readonly="1"/>
                                <field name="total_actual" readonly="1"/>
                                <field name="total_variance" readonly="1"/>
                                <field name="total_variance_percentage" readonly="1"/>
                            </group>
                        </group>
                        <separator string="BOQ Lines"/>
                        <field name="line_ids">
                            <tree editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="description"/>
                                <field name="quantity_planned"/>
                                <field name="unit_cost_planned"/>
                                <field name="total_planned" readonly="1"/>
                                <field name="quantity_actual" readonly="1"/>
                                <field name="total_actual" readonly="1"/>
                                <field name="variance" readonly="1"/>
                                <field name="variance_percentage" readonly="1"/>
                            </tree>
                        </field>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Construction BOQ List View -->
        <record id="view_construction_boq_list" model="ir.ui.view">
            <field name="name">construction.boq.list</field>
            <field name="model">construction.boq</field>
            <field name="arch" type="xml">
                <tree string="BOQs">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="total_planned" sum="Planned"/>
                    <field name="total_actual" sum="Actual"/>
                    <field name="total_variance" sum="Variance"/>
                </tree>
            </field>
        </record>

        <!-- Action for Construction BOQ -->
        <record id="action_construction_boq" model="ir.actions.act_window">
            <field name="name">BOQ</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">construction.boq</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="menu_construction_boq" name="BOQ" parent="menu_construction_root" action="action_construction_boq" sequence="80"/>

    </data>
</odoo>
