<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Construction Timesheet Form View -->
        <record id="view_construction_timesheet_form" model="ir.ui.view">
            <field name="name">construction.timesheet.form</field>
            <field name="model">construction.timesheet</field>
            <field name="arch" type="xml">
                <form string="Timesheet">
                    <sheet>
                        <group>
                            <group>
                                <field name="worker_id"/>
                                <field name="project_id"/>
                                <field name="stage_id"/>
                            </group>
                            <group>
                                <field name="date"/>
                                <field name="hours"/>
                                <field name="cost" readonly="1"/>
                            </group>
                        </group>
                        <field name="notes"/>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Construction Timesheet List View -->
        <record id="view_construction_timesheet_list" model="ir.ui.view">
            <field name="name">construction.timesheet.list</field>
            <field name="model">construction.timesheet</field>
            <field name="arch" type="xml">
                <tree string="Timesheets">
                    <field name="date"/>
                    <field name="worker_id"/>
                    <field name="project_id"/>
                    <field name="stage_id"/>
                    <field name="hours"/>
                    <field name="cost" sum="Total"/>
                </tree>
            </field>
        </record>

        <!-- Action for Construction Timesheet -->
        <record id="action_construction_timesheet" model="ir.actions.act_window">
            <field name="name">Timesheets</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">construction.timesheet</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="menu_construction_timesheets" name="Timesheets" parent="menu_construction_root" action="action_construction_timesheet" sequence="50"/>

    </data>
</odoo>
