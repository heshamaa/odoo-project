<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Construction Groups -->
        <record id="group_construction_user" model="res.groups">
            <field name="name">Construction User</field>
            <field name="comment">Can view and create construction records</field>
        </record>

        <record id="group_construction_manager" model="res.groups">
            <field name="name">Construction Manager</field>
            <field name="comment">Full access to construction management</field>
            <field name="implied_ids" eval="[(4, ref('group_construction_user'))]"/>
        </record>

        <!-- Sequence for Change Orders -->
        <record id="seq_construction_change_order" model="ir.sequence">
            <field name="name">Construction Change Order</field>
            <field name="code">construction.change.order</field>
            <field name="prefix">CO</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Demo Client -->
        <record id="partner_client_demo" model="res.partner">
            <field name="name">ABC Construction Client</field>
            <field name="customer_rank">1</field>
        </record>

        <!-- Demo Workers -->
        <record id="worker_engineer" model="construction.worker">
            <field name="name">Ahmed Engineer</field>
            <field name="phone">+201001234567</field>
            <field name="email">ahmed@example.com</field>
            <field name="daily_rate">800.0</field>
        </record>

        <record id="worker_laborer" model="construction.worker">
            <field name="name">Mohammed Laborer</field>
            <field name="phone">+201001234568</field>
            <field name="email">mohammed@example.com</field>
            <field name="daily_rate">400.0</field>
        </record>

        <!-- Demo Equipment -->
        <record id="equipment_excavator" model="construction.equipment">
            <field name="name">Excavator CAT 320</field>
            <field name="type">machinery</field>
            <field name="ownership">rented</field>
            <field name="daily_cost">5000.0</field>
            <field name="serial_number">CAT-320-001</field>
        </record>

        <record id="equipment_scaffold" model="construction.equipment">
            <field name="name">Steel Scaffolding</field>
            <field name="type">tools</field>
            <field name="ownership">owned</field>
            <field name="daily_cost">1000.0</field>
        </record>

        <!-- Demo Project -->
        <record id="project_residential" model="construction.project">
            <field name="name">Residential Building - Cairo</field>
            <field name="client_id" ref="partner_client_demo"/>
            <field name="start_date">2024-01-15</field>
            <field name="end_date">2024-12-31</field>
            <field name="budget">10000000.0</field>
            <field name="state">ongoing</field>
            <field name="description">5-story residential building construction in Cairo</field>
        </record>

        <!-- Demo Stages -->
        <record id="stage_foundation" model="construction.stage">
            <field name="name">Foundation</field>
            <field name="project_id" ref="project_residential"/>
            <field name="planned_cost">2000000.0</field>
            <field name="start_date">2024-01-15</field>
            <field name="end_date">2024-03-15</field>
            <field name="progress">100.0</field>
            <field name="sequence">1</field>
        </record>

        <record id="stage_structure" model="construction.stage">
            <field name="name">Structure</field>
            <field name="project_id" ref="project_residential"/>
            <field name="planned_cost">3000000.0</field>
            <field name="start_date">2024-03-16</field>
            <field name="end_date">2024-07-15</field>
            <field name="progress">60.0</field>
            <field name="sequence">2</field>
        </record>

        <record id="stage_finishing" model="construction.stage">
            <field name="name">Finishing</field>
            <field name="project_id" ref="project_residential"/>
            <field name="planned_cost">3000000.0</field>
            <field name="start_date">2024-07-16</field>
            <field name="end_date">2024-12-31</field>
            <field name="progress">0.0</field>
            <field name="sequence">3</field>
        </record>

        <!-- Demo Milestones -->
        <record id="milestone_foundation_complete" model="construction.milestone">
            <field name="name">Foundation Complete</field>
            <field name="project_id" ref="project_residential"/>
            <field name="percentage">25.0</field>
            <field name="approved">1</field>
            <field name="sequence">1</field>
        </record>

        <record id="milestone_structure_complete" model="construction.milestone">
            <field name="name">Structure Complete</field>
            <field name="project_id" ref="project_residential"/>
            <field name="percentage">60.0</field>
            <field name="approved">0</field>
            <field name="sequence">2</field>
        </record>

        <!-- Demo BOQ -->
        <record id="boq_residential" model="construction.boq">
            <field name="name">Residential BOQ</field>
            <field name="project_id" ref="project_residential"/>
        </record>

        <!-- Demo BOQ Lines -->
        <record id="boq_line_steel" model="construction.boq.line">
            <field name="boq_id" ref="boq_residential"/>
            <field name="description">Steel Reinforcement</field>
            <field name="quantity_planned">500.0</field>
            <field name="unit_cost_planned">1000.0</field>
            <field name="sequence">1</field>
        </record>

        <record id="boq_line_concrete" model="construction.boq.line">
            <field name="boq_id" ref="boq_residential"/>
            <field name="description">Ready Mix Concrete</field>
            <field name="quantity_planned">1000.0</field>
            <field name="unit_cost_planned">500.0</field>
            <field name="sequence">2</field>
        </record>

    </data>
</odoo>
