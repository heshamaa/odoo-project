<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_material_request_tree" model="ir.ui.view">
        <field name="name">construction.material.request.tree</field>
        <field name="model">construction.material.request</field>
        <field name="arch" type="xml">
            <tree string="Material Requests" decoration-info="state == 'submitted'" decoration-success="state == 'approved'">
                <field name="name"/>
                <field name="project_id"/>
                <field name="requested_by"/>
                <field name="request_date"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="view_material_request_form" model="ir.ui.view">
        <field name="name">construction.material.request.form</field>
        <field name="model">construction.material.request</field>
        <field name="arch" type="xml">
            <form string="Material Request">
                <header>
                 <button name="action_submit" string="Submit" type="object" class="oe_highlight" invisible="state != 'draft'"/>
    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'submitted'" groups="base.group_system"/>
    
    <button name="action_create_purchase_order" string="Create RFQ" type="object" class="oe_highlight" invisible="state != 'approved'"/>
    
    <button name="action_draft" string="Set to Draft" type="object" invisible="state == 'draft'"/>
    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id" readonly="state != 'draft'"/>
                            <field name="project_manager_id"/>
                        </group>
                        <group>
                            <field name="request_date" readonly="state != 'draft'"/>
                            <field name="requested_by" readonly="1"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Materials">
                            <field name="request_line_ids" readonly="state != 'draft'">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="description"/>
                                    <field name="quantity"/>
                                    <field name="uom_id"/>
                                    <field name="date_required"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

 
</odoo>