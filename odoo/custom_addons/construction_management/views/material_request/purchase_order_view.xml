<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_inherit_construction" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.construction</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <field name="partner_ref" position="after">
                <field name="project_id"/>
                <field name="material_request_id" readonly="1"/>
            </field>
        </field>
    </record>

    <record id="view_purchase_order_tree_inherit_construction" model="ir.ui.view">
        <field name="name">purchase.order.tree.inherit.construction</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="project_id" optional="show"/>
            </field>
        </field>
    </record>
</odoo>