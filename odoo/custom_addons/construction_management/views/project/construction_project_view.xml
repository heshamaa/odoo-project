<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_construction_project_tree" model="ir.ui.view">
        <field name="name">construction.project.tree</field>
        <field name="model">construction.project</field>
        <field name="arch" type="xml">
            <tree string="Projects" decoration-info="state == 'draft'" decoration-success="state == 'active'">
                <field name="code"/>
                <field name="name"/>
                <field name="project_type"/>
                <field name="site_engineer_id"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="view_construction_project_form" model="ir.ui.view">
        <field name="name">construction.project.form</field>
        <field name="model">construction.project</field>
        <field name="arch" type="xml">
            <form string="Project">
                <header>
                    <button name="%(base.action_partner_form)d" string="Start Project" type="action" class="oe_highlight" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="code" readonly="1"/>
                        </h1>
                        <h1>
                            <field name="name" placeholder="Project Name e.g. Uptown Cairo Villa"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_type"/>
                            <field name="site_location"/>
                            <field name="warehouse_id"/>
                        </group>
                        <group>
                            <field name="site_engineer_id"/>
                            <field name="project_manager_id"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Budget &amp; Finance">
                            <group>
                                <field name="budget"/>
                            </group>
                        </page>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

   
</odoo>